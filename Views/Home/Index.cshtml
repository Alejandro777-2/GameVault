@{
    ViewData["Title"] = "Inicio";
}

<div class="container py-5">
    <div class="row justify-content-center text-center">
        <div class="col-lg-8">
            <h1 class="display-4 fw-bold mb-3">Bienvenido a GameVault</h1>
            <p class="lead text-muted mb-4">
                La plataforma para coleccionistas de videojuegos retro en Latinoamérica
            </p>
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-4">
                    Explorar catálogo
                </a>
                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-secondary btn-lg px-4">
                    Crear cuenta
                </a>
            </div>
        </div>
    </div>
</div>
