@model AssetIndexViewModel
@{
    ViewData["Title"] = "Catálogo de Activos";
}

@functions {
    static string ConditionBadgeClass(Condition c) => c switch
    {
        Condition.Mint => "bg-success",
        Condition.Good => "bg-primary",
        Condition.Fair => "bg-warning text-dark",
        Condition.Poor => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Catálogo de Activos</h1>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-action="Create" class="btn btn-primary">Registrar nuevo activo</a>
    }
</div>

<form method="get" asp-action="Index" class="row g-2 mb-4 align-items-end">
    <input type="hidden" name="page" value="1" />
    <div class="col-12 col-md-4">
        <input type="text" name="searchTerm" value="@Model.SearchTerm"
               class="form-control" placeholder="Buscar por título..." />
    </div>
    <div class="col-6 col-md-3">
        <select name="platform" class="form-select">
            <option value="">Todas las plataformas</option>
            @foreach (var item in Html.GetEnumSelectList<Platform>())
            {
                var sel = Model.PlatformFilter.HasValue
                    && (int)Model.PlatformFilter.Value == int.Parse(item.Value!);
                <option value="@item.Value" selected="@(sel ? "selected" : null)">@item.Text</option>
            }
        </select>
    </div>
    <div class="col-6 col-md-2">
        <select name="condition" class="form-select">
            <option value="">Todos los estados</option>
            @foreach (var item in Html.GetEnumSelectList<Condition>())
            {
                var sel = Model.ConditionFilter.HasValue
                    && (int)Model.ConditionFilter.Value == int.Parse(item.Value!);
                <option value="@item.Value" selected="@(sel ? "selected" : null)">@item.Text</option>
            }
        </select>
    </div>
    <div class="col-6 col-md-2">
        <button type="submit" class="btn btn-outline-secondary w-100">Buscar</button>
    </div>
    <div class="col-6 col-md-1">
        <a asp-action="Index" class="btn btn-outline-danger w-100" title="Limpiar filtros">✕</a>
    </div>
</form>

@if (!Model.Assets.Any())
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:3rem">🎮</div>
        <p class="mt-3 mb-0">No se encontraron activos con los filtros seleccionados.</p>
        @if (Model.SearchTerm != null || Model.PlatformFilter != null || Model.ConditionFilter != null)
        {
            <a asp-action="Index" class="btn btn-link mt-2">Limpiar filtros</a>
        }
    </div>
}
else
{
    <p class="text-muted small mb-3">@Model.TotalItems activo(s) encontrado(s)</p>

    <div class="row g-4">
        @foreach (var asset in Model.Assets)
        {
            <div class="col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm position-relative">
                    @if (!string.IsNullOrEmpty(asset.ImageUrl))
                    {
                        <img src="@asset.ImageUrl" class="card-img-top"
                             style="height:200px; object-fit:cover" alt="@asset.Title" />
                    }
                    else
                    {
                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center"
                             style="height:200px">
                            <span class="text-muted small">Sin imagen</span>
                        </div>
                    }
                    <div class="card-body">
                        <h5 class="card-title text-truncate" title="@asset.Title">@asset.Title</h5>
                        <div class="mb-2">
                            <span class="badge bg-secondary">@asset.Platform.GetDisplayName()</span>
                            <span class="badge @ConditionBadgeClass(asset.Condition)">@asset.Condition.GetDisplayName()</span>
                        </div>
                        <p class="card-text small text-muted mb-1">Año: @asset.Year</p>
                        <p class="card-text fw-bold">
                            $ @asset.EstimatedValue.ToString("N0", new CultureInfo("es-EC"))
                        </p>
                    </div>
                    <div class="card-footer bg-transparent small text-muted">
                        Publicado por @asset.OwnerDisplayName
                    </div>
                    <a class="stretched-link" asp-action="Details" asp-route-id="@asset.Id"
                       aria-label="Ver @asset.Title"></a>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Paginación de activos" class="mt-4">
            <ul class="pagination justify-content-center flex-wrap">
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.CurrentPage - 1)"
                       asp-route-searchTerm="@Model.SearchTerm"
                       asp-route-platform="@Model.PlatformFilter"
                       asp-route-condition="@Model.ConditionFilter">Anterior</a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-searchTerm="@Model.SearchTerm"
                           asp-route-platform="@Model.PlatformFilter"
                           asp-route-condition="@Model.ConditionFilter">@i</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.CurrentPage + 1)"
                       asp-route-searchTerm="@Model.SearchTerm"
                       asp-route-platform="@Model.PlatformFilter"
                       asp-route-condition="@Model.ConditionFilter">Siguiente</a>
                </li>
            </ul>
        </nav>
    }
}
